<!DOCTYPE html>
<html>
<head>
  <title>createElement Div Example</title>
  <style>
    #box-container {
      border: 2px dashed #555;
      padding: 20px;
      margin-top: 20px;
    }
  </style>
</head>
<body>

<button onclick="addBox()">Add Box</button>

<div id="box-container">
  <h3>Boxes will appear below:</h3>
</div>

<script>
  function addBox() {
    // Step 1: Create a div element
    const box = document.createElement("div");

    // Step 2: Set styles and content
    box.textContent = "I'm a new box!";
    box.style.width = "150px";
    box.style.height = "80px";
    box.style.backgroundColor = "#90ee90";
    box.style.margin = "10px 0";
    box.style.padding = "10px";
    box.style.border = "1px solid #333";

    // Step 3: Append it to the container
    const container = document.getElementById("box-container");
    container.appendChild(box);
  }
</script>

</body>
</html>
